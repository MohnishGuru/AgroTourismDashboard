    // DataTable Initialize 
    function initializeDataTable() {
        var now = new Date().toLocaleString('en-IN');

        $('#dataTable').DataTable({
            destroy: true,
            pageLength: 10,
            responsive: true,
            searching: true,
            ordering: true,
            dom: '<"top"Bfl>rt<"bottom"ip><"clear">',
            columnDefs: [
                {
                    targets: 1,
                    render: function (data, type, row, meta) {
                        return meta.row + 1;
                    }
                }
            ],
            buttons: [
                {
                    extend: 'excel',
                    text: '<i class="fa-solid fa-file-excel"></i>',
                    title: currentTitle,
                    messageTop: 'Generated on: ' + now,
                    action: function (e, dt, button, config) {
                        if ($('.rowCheck:checked').length === 0) {
                            alert("Please select at least one row to export");
                            return;
                        }
                        if (!confirm("Are you sure you want to download Excel?")) {
                            return;
                        }
                        $.fn.dataTable.ext.buttons.excelHtml5.action.call(this, e, dt, button, config);
                    },
                    exportOptions: {
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheck').prop('checked');
                        },
                        columns: ':visible:not(:first-child)'
                    }
                },
                {
                    extend: 'pdf',
                    text: '<i class="fa-solid fa-file-pdf"></i>',
                    title: currentTitle,
                    messageTop: 'Generated on: ' + now,
                    action: function (e, dt, button, config) {
                        if ($('.rowCheck:checked').length === 0) {
                            alert("Please select at least one row to export");
                            return;
                        }
                        if (!confirm("Are you sure you want to download PDF?")) {
                            return;
                        }
                        $.fn.dataTable.ext.buttons.pdfHtml5.action.call(this, e, dt, button, config);
                    },
                    exportOptions: {
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheck').prop('checked');
                        },
                        columns: ':visible:not(:first-child)'
                    },
                    customize: function (doc) {
                        doc.styles.title.alignment = 'center';
                        doc.styles.message.alignment = 'center';
                    }
                },
                {
                    extend: 'print',
                    text: '<i class="fa-solid fa-print"></i>',
                    title: currentTitle,
                    messageTop: 'Generated on: ' + now,
                    action: function (e, dt, button, config) {
                        if ($('.rowCheck:checked').length === 0) {
                            alert("Please select at least one row to print");
                            return;
                        }
                        if (!confirm("Are you sure you want to print this report?")) {
                            return;
                        }
                        $.fn.dataTable.ext.buttons.print.action.call(this, e, dt, button, config);
                    },
                    exportOptions: {
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheck').prop('checked');
                        },
                        columns: ':visible:not(:first-child)'
                    }
                }
            ]
        });
    }
    // Smooth scrolling and hover effects - ONLY for dashboard elements
    $(document).ready(function () {
        $('html, body').css('scroll-behavior', 'smooth');

        // Hover effects ONLY for dashboard cards and chart containers
        $('.dashboard-card, .chart-container').hover(
            function () { $(this).css('transform', 'translateY(-5px)'); },
            function () { $(this).css('transform', 'translateY(0)'); }
        );
    });


</script>