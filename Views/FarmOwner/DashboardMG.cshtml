    // Revenue Details List
    function loadRevenueDetailsList(month, filterType) {
        currentTitle = month + " - Revenue Details";
        $("#modalTitle").text(currentTitle + " (Loading...)");

        $.ajax({
            url: "/FarmOwner/GetRevenueDetailsListMG",
            type: "GET",
            data: {
                month: month,
                filterType: filterType
            },
            success: function (data) {
                $("#modalTitle").text(currentTitle);

                if ($.fn.DataTable.isDataTable('#dataTable')) {
                    $('#dataTable').DataTable().clear().destroy();
                }

                $('#dataTable thead').html('<tr id="modalHead"></tr>');
                $('#dataTable tbody').empty();

                let head = `
                <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                <th>Sr No</th>
                <th>FarmHouse Name</th>
                <th>Visitor Name</th>
                <th>Booking Date</th>
                <th>Package Name</th>
                <th>No Of Guest</th>
                <th>Amount (₹)</th>
                <th>Status</th>`;

                $("#modalHead").html(head);

                let rows = "";
                if (!data || data.length === 0) {
                    let colCount = 9;
                    rows = `<tr><td colspan="${colCount}" class="text-center">No Data Found</td></tr>`;
                } else {
                    $.each(data, function (i, row) {
                        rows += "<tr>";
                        rows += `<td><input type="checkbox" class="rowCheck"></td>`;
                        rows += `<td>${i + 1}</td>`;
                        $.each(row, function (j, col) {
                            if (typeof col === 'string' && col.includes('12:00:00 AM')) {
                                col = col.split(' ')[0];
                            } else if (typeof col === 'number') {
                                col = col.toLocaleString('en-IN');
                            }
                            rows += "<td>" + col + "</td>";
                        });
                        rows += "</tr>";
                    });
                }

                $("#modalBody").html(rows);

                var modal = new bootstrap.Modal(document.getElementById('listModal'));
                modal.show();

                // DataTable Initialize
                setTimeout(function () {
                    if ($('#dataTable tbody tr').length > 0 &&
                        $('#dataTable tbody td:first').text() !== "No Data Found") {

                        initializeDataTable();
                    }
                }, 200);
            }
        });
    }

