<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- Your EXACT ORIGINAL JavaScript - No changes -->
<script>
    let currentFlag = "";
    let currentTitle = "";

    function loadList(flag, title) {
        currentFlag = flag;
        currentTitle = title;

        $("#modalTitle").text(title + " (Loading...)");

        $.ajax({
            url: "/FarmOwner/GetListMG",
            type: "GET",
            data: { flag: flag },

            success: function (data) {
                $("#modalTitle").text(title);

                if ($.fn.DataTable.isDataTable('#dataTable')) {
                    $('#dataTable').DataTable().clear().destroy();
                }

                $('#dataTable thead').html('<tr id="modalHead"></tr>');
                $('#dataTable tbody').empty();

                let head = "";
                let rows = "";

                // ===== HEADERS =====
                if (flag === "ListTotalbookingMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                    <th>Sr No</th>
                    <th>FarmHouse Name</th>
                    <th>Booking Date</th>
                    <th>No Of Guest</th>
                    <th>Location</th>`;
                }
                else if (flag === "ListWeeklybookingMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                     <th>Sr No</th>
                    <th>Visitor Name</th>
                    <th>Package Name</th>
                    <th>Booking Date</th>
                    <th>No Of Guest</th>
                    <th>Daily Amount (₹)</th>
                    <th>Booking Amount (₹)</th>
                    <th>Weekly Amount (₹)</th>`;
                }
                else if (flag === "ListMonthlybookingMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                    <th>Sr No</th>
                    <th>Package Name</th>
                    <th>Month Name</th>
                    <th>Month Number</th>
                    <th>Year Number</th>
                    <th>Total Revenue (₹)</th>`;
                }
                else if (flag === "ListUpcomingbookingMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                    <th>Sr No</th>
                    <th>Farm House Name</th>
                    <th>Visitor Name</th>
                    <th>No Of Guest</th>
                    <th>Total Amount (₹)</th>
                    <th>Status</th>`;
                }
                else if (flag === "ListCancleedbookingMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                    <th>Sr No</th>
                    <th>Farm House Name</th>
                    <th>Visitor Name</th>
                    <th>Booking Date</th>
                    <th>Check In Date</th>
                    <th>No Of Guest</th>
                    <th>Total Amount (₹)</th>
                    <th>Status</th>`;
                }
                else if (flag === "ListCurrentSubscriptionMG") {
                    head = `
                    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
                    <th>Sr No</th>
                    <th>Farm House Name</th>
                    <th>Plan Name</th>
                    <th>Purchase Date</th>
                    <th>End Date</th>
                    <th>Days Left</th>`;
                }
                else if (flag === "ListClosedFarmHouseMG") {
                    head = `
    <th style="width:40px"><input type="checkbox" id="selectAll"></th>
    <th>Sr No</th>
    <th>Farm House Name</th>
    <th>Farm Address</th>
    <th>Status Name</th>
    <th>Closed Date</th>`;
                }

                $("#modalHead").html(head);

                // ===== ROWS =====
                if (!data || data.length === 0) {
                    let colCount = (head.match(/<th/g) || []).length;
                    rows = `<tr><td colspan="${colCount}" class="text-center">No Data Found</td></tr>`;
                }
                else {
                    $.each(data, function (i, row) {
                        rows += "<tr>";
                        rows += `<td><input type="checkbox" class="rowCheck"></td>`;
                        rows += `<td>${i + 1}</td>`;
                        $.each(row, function (j, col) {
                            if (typeof col === 'string' && col.includes('12:00:00 AM')) {
                                col = col.split(' ')[0];
                            }
                            else if (typeof col === 'number') {
                                col = col.toLocaleString('en-IN');
                            }
                            rows += "<td>" + col + "</td>";
                        });

                        rows += "</tr>";
                    });
                }

                $("#modalBody").html(rows);

                // SHOW MODAL - ORIGINAL POSITION
                var modal = new bootstrap.Modal(document.getElementById('listModal'));
                modal.show();

                // ===== INIT DATATABLE - ORIGINAL STYLING =====
                setTimeout(function () {
                    if ($('#dataTable tbody tr').length > 0 &&
                        $('#dataTable tbody td:first').text() !== "No Data Found") {

                        var now = new Date().toLocaleString('en-IN');

                        $('#dataTable').DataTable({

                            destroy: true,
                            pageLength: 10,
                            responsive: true,
                            searching: true,
                            ordering: true,

                            dom: '<"top"Bfl>rt<"bottom"ip><"clear">',

                            columnDefs: [
                                {
                                    targets: 1,
                                    render: function (data, type, row, meta) {
                                        return meta.row + 1;
                                    }
                                }
                            ],

                            buttons: [

                                {
                                    extend: 'excel',
                                    text: '<i class="fa-solid fa-file-excel"></i>',
                                    title: currentTitle,
